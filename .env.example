# === Wallets (REQUIRED — must be different wallets) ===
# Generate: python3 -c "from eth_account import Account; a = Account.create(); print(a.key.hex())"
OPERATOR_PRIVATE_KEY=0x...    # Owns Sentinel's ERC-8004 identity
EVALUATOR_PRIVATE_KEY=0x...   # Submits giveFeedback() to Reputation Registry
AUDITOR_PRIVATE_KEY=0x...     # Optional: self-reputation

# === API Keys (REQUIRED) ===
VENICE_API_KEY=...            # Get from https://venice.ai/settings/api

# === Network ===
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
USE_TESTNET=true

# === EAS (set after running: python3 main.py register-schema) ===
EAS_SCHEMA_UID=
